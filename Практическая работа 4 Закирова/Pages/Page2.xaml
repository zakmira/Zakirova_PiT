<Page x:Class="Практическая_работа_4_Закирова.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Практическая_работа_4_Закирова.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="WhiteSmoke"
      Title="Page2">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" 
        Source="\Images\formula 2.png" 
        Height="100" 
        Margin="5"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <Label Content="x =" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="X" Width="100" Margin="5" ToolTip="Введите значение x"/>

            <Label Content="p =" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="P" Width="100" Margin="5" ToolTip="Введите значение p"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Выберите функцию f(x):" Margin="5">
            <StackPanel Orientation="Horizontal" Margin="5">
                <RadioButton x:Name="ShX" Content="sh(x)" 
                             Margin="5" GroupName="FuncGroup"
                             ToolTip="Гиперболический синус: sh(x) = (e^x - e^-x)/2"/>
                <RadioButton x:Name="X2" Content="x²" 
                             Margin="5" GroupName="FuncGroup"
                             ToolTip="Квадрат числа x"/>
                <RadioButton x:Name="Exp" Content="e^x" 
                             Margin="5" GroupName="FuncGroup" IsChecked="True"
                             ToolTip="Экспонента"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5">
            <Button Content="Вычислить" Click="Calculate_Click" 
                    Width="100" Margin="5" Padding="5"
                    ToolTip="Нажмите, чтобы узнать результат"/>
            <Button Content="Очистить" Click="Clear_Click" 
                    Width="100" Margin="5" Padding="5"
                    ToolTip="Нажмите для очистки всех полей"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5">
            <Label Content="Ответ" VerticalAlignment="Center" 
                   FontSize="14" FontWeight="Bold" Margin="5"/>
            <TextBox x:Name="Result" Width="200" Margin="5" 
                     IsReadOnly="True" ToolTip="Результат вычисления"/>
        </StackPanel>
    </Grid>
</Page>
