<Page x:Class="kinoshechka.Pages.Order"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kinoshechka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="AliceBlue"
      Title="Order">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="Назад"
                HorizontalAlignment="Left"
                Margin="10,15,0,20"
                Click="Back_Click" Width="71"/>

        <TextBlock Grid.Row="0" Text="Подтверждение покупки"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,10"/>

        <Border Grid.Row="1" Padding="10"
                BorderBrush="Gray" BorderThickness="1"
                Background="#F5F5F5" CornerRadius="5">
            <StackPanel>
                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="Фильм:" FontWeight="Bold"/>
                    <TextBlock x:Name="MovieTitleText" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="Зал:" FontWeight="Bold"/>
                    <TextBlock x:Name="HallNameText" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="Дата:" FontWeight="Bold"/>
                    <TextBlock x:Name="SessionDateText" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="Время:" FontWeight="Bold"/>
                    <TextBlock x:Name="SessionTimeText" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="Выбранные места:" FontWeight="Bold"/>
                    <TextBlock x:Name="SelectedSeatsText" FontSize="16"/>
                </StackPanel>

                <Border BorderBrush="Gray" BorderThickness="0,1,0,0" Margin="0,5,0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Итого к оплате:" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="TotalPriceText" 
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#4CAF50"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Content="Отмена"
                            Width="70"
                            Height="40"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"/>

                    <Button Grid.Column="2" 
                            Content="Подтвердить"
                            Width="80"
                            Height="40"
                            Margin="0,0,10,0"
                            Click="Confirm_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
            