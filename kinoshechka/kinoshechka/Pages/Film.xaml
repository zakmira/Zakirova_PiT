<Page x:Class="kinoshechka.Pages.Film"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kinoshechka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800" Background="AliceBlue"
      Title="Film">

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <Button Content="На главную"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Padding="15,8"
                    Margin="0,0,0,5"
                    Click="Back_Click"
                    FontSize="14"/>

            <Border Grid.Row="1" Margin="0,0,0,10" Padding="20"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    Background="White" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="250" Height="250"
                            BorderBrush="#CCCCCC" BorderThickness="1"
                            Background="#F5F5F5"
                            HorizontalAlignment="Left">
                        <Image x:Name="Image" 
                               Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="25,0,0,0">
                        <TextBlock x:Name="TitleText" 
                                   FontSize="28" FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Рейтинг: " FontWeight="Bold" Width="120"/>
                                <TextBlock x:Name="RatingText" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Возрастное ограничение: " FontWeight="Bold" Width="150"/>
                                <TextBlock x:Name="AgeRatingText" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Премьера: " FontWeight="Bold" Width="120"/>
                                <TextBlock x:Name="ReleaseDateText" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Жанр: " FontWeight="Bold" Width="120"/>
                                <TextBlock x:Name="GenresText" FontSize="16" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,15,0,8"/>
                        <TextBlock x:Name="DescriptionText" 
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="20"/>
                    </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                <TextBlock Text="Сеансы"
                           FontSize="22" FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <ItemsControl x:Name="SessionsItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                            <Border Margin="0,0,0,12" Padding="15"
                                    BorderBrush="#CCCCCC" BorderThickness="1"
                                    Background="White" CornerRadius="5">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Дата: " FontWeight="Bold" Width="80"/>
                                                <TextBlock Text="{Binding SessionDate, StringFormat=dd.MM.yyyy}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Время: " FontWeight="Bold" Width="80"/>
                                                <TextBlock Text="{Binding SessionTime, StringFormat=hh\\:mm}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Зал: " FontWeight="Bold" Width="80"/>
                                                <TextBlock Text="{Binding HallName}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Категория: " FontWeight="Bold" Width="80"/>
                                                <TextBlock Text="{Binding HallClassification}"/>
                                            </StackPanel>
                                        </StackPanel>

                                    <Button Grid.Column="1" 
                                            Content="Выбрать места"
                                            Padding="20,10"
                                            VerticalAlignment="Center"
                                            Margin="15,0,0,0"
                                            FontSize="14"
                                            Click="SelectSeats_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

