<Page x:Class="kinoshechka.Pages.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kinoshechka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="AliceBlue"
      Title="Register">

        <Grid Margin="25">
            <StackPanel>
            <Button Content="На главную"
                    HorizontalAlignment="Left"
                    Padding="10,5"
                    Margin="0,0,0,20"
                    Click="Back_Click"/>    

            <TextBlock Text="Регистрация" 
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

                <TextBlock Text="Имя пользователя:" Margin="0,0,0,5"/>
                <TextBox x:Name="UserNameBox" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Повторите пароль:" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Padding="5" Margin="0,0,0,15"/>

                <Button Content="Зарегистрироваться" 
                        Padding="15,10" FontSize="16"
                        Click="Register_Click"/>

                <TextBlock x:Name="ErrorText" Foreground="Red"
                           TextWrapping="Wrap"/>

                <TextBlock Margin="0,5,0,0" HorizontalAlignment="Center">
                <Run Text="Уже есть аккаунт? "/>
                <Hyperlink Click="Login_Click">
                    <Run Text="Войти" FontWeight="Bold"/>
                </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
</Page>
