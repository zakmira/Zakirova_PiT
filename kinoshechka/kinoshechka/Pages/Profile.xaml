<Page x:Class="kinoshechka.Pages.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kinoshechka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="На главную"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Padding="15,8"
                Click="Back_Click"/>

        <Border Grid.Row="1" Margin="0,10,0,15" Padding="15"
                BorderBrush="Gray" BorderThickness="1"
                Background="#F5F5F5" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Информация об аккаунте"
                           FontSize="20" FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя пользователя:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UserNameText" Margin="10,0,0,0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Всего билетов:" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalTicketsText" Margin="10,10,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="Мои билеты"
                       FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,10"
                       VerticalAlignment="Top"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" 
                      Margin="0,30,0,0">
            <ItemsControl x:Name="TicketsItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,15" Padding="15"
                                BorderBrush="Gray" BorderThickness="1"
                                Background="White" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="100" Height="150" 
                                        BorderBrush="Gray" BorderThickness="1"
                                        Background="#E0E0E0"
                                        Margin="0,0,15,0">
                                <Image Source="{Binding CoverImage, Mode=OneWay, TargetNullValue=''}" 
                                       Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding MovieTitle, Mode=OneWay}" 
                                               FontWeight="Bold" FontSize="16"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Дата: "/>
                                            <Run Text="{Binding SessionDate, Mode=OneWay, StringFormat=dd.MM.yyyy}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Время: "/>
                                            <Run Text="{Binding SessionTime, Mode=OneWay, StringFormat=hh\\:mm}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Зал: "/>
                                            <Run Text="{Binding HallName, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Место: "/>
                                            <Run Text="{Binding SeatNumber, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Цена: "/>
                                            <Run Text="{Binding Price, Mode=OneWay, StringFormat=F2}"/>
                                            <Run Text=" ₽"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,5">
                                            <Run Text="Покупка: "/>
                                            <Run Text="{Binding PurchaseDate, Mode=OneWay, StringFormat=dd.MM.yyyy HH:mm}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>