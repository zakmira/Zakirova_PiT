<Page x:Class="kinoshechka.Pages.Auth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kinoshechka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="AliceBlue"
      Title="Auth">

    <Grid Margin="30">
        <StackPanel>
            <Button Content="На главную"
                    HorizontalAlignment="Left"
                    Padding="10,5"
                    Margin="0,0,0,20"
                    Click="Back_Click"/>

            <TextBlock Text="Вход в аккаунт" 
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"/>

            <TextBlock Text="Имя пользователя:" Margin="0,0,0,5"/>
            <TextBox x:Name="UserNameBox" Padding="10" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Padding="10" Margin="0,0,0,20"/>

            <Button Content="Войти" 
                    Padding="10,10" FontSize="16"
                    Click="Auth_Click"/>

            <TextBlock Margin="0,5,0,0" HorizontalAlignment="Center">
                <Run Text="Нет аккаунта? "/>
                <Hyperlink Click="Register_Click">
                    <Run Text="Зарегистрироваться" FontWeight="Bold"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>